{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkaik.app/schema/project-bundle.json",
  "version": 2,
  "title": "Arkaik ProjectBundle",
  "description": "The import/export format for an Arkaik product graph. Contains a project, its nodes (flows, views, data models, API endpoints), and edges (relationships between nodes).",
  "type": "object",
  "required": [
    "project",
    "nodes",
    "edges"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "description": "Bundle Format contract version. Absent means 1 (docs/spec/bundle-format.md § Schema Versioning). Older versions migrate through an explicit chain; unknown fields from newer versions are preserved on re-export.",
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "project": {
      "$ref": "#/$defs/Project"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Node"
      },
      "description": "All nodes in the project graph."
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Edge"
      },
      "description": "All edges (relationships) between nodes."
    },
    "journal": {
      "description": "Optional embedded journal events — the Level 2 interchange projection (docs/spec/journal.md). Canonical storage in repos is the JSONL sidecar; a bundle without a journal is Level 0/1, not an error.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/JournalEvent"
      }
    }
  },
  "$defs": {
    "Project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique project identifier."
        },
        "title": {
          "type": "string",
          "description": "Project title."
        },
        "description": {
          "description": "Optional project description.",
          "type": "string"
        },
        "version": {
          "description": "Current version label of the mapped product (free-form; semver recommended, not required). Version history lives in the journal as release.tagged events.",
          "type": "string"
        },
        "root_node_id": {
          "description": "ID of the root node used as the canvas entry point. Should reference an existing node.",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/ProjectMetadata"
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 creation timestamp."
        },
        "updated_at": {
          "type": "string",
          "description": "ISO 8601 last-update timestamp."
        },
        "archived_at": {
          "description": "ISO 8601 archive timestamp, or null if active.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "title",
        "created_at",
        "updated_at"
      ],
      "additionalProperties": true
    },
    "ProjectMetadata": {
      "type": "object",
      "properties": {
        "view_card_variant": {
          "type": "string",
          "enum": [
            "compact",
            "large"
          ]
        },
        "maps": {
          "description": "Stored map definitions (docs/spec/maps.md § Storage) — additive; unknown fields preserved.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/MapDefinition"
          }
        }
      },
      "additionalProperties": {},
      "description": "Optional project-level UI settings."
    },
    "MapDefinition": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Kebab-case, unique within the project; built-in ids (journey, system) are reserved."
        },
        "title": {
          "type": "string",
          "description": "Display title."
        },
        "description": {
          "description": "What this map is for.",
          "type": "string"
        },
        "kind": {
          "type": "string",
          "description": "Map kind: journey | system. Selects the renderer and selection defaults; unrecognized kinds are preserved and listed as unrenderable."
        },
        "species": {
          "description": "Node filter; defaults by kind (journey: flow+view; system: view+api-endpoint+data-model).",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edge_types": {
          "description": "Edge filter; defaults by kind (journey: composes; system: calls+displays+queries).",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "root_node_id": {
          "description": "Scope anchor: the subgraph is the undirected neighborhood reachable from this node.",
          "type": "string"
        },
        "depth": {
          "description": "Traversal bound from the root; absent = unbounded.",
          "type": "number"
        },
        "layout": {
          "description": "Renderer layout hints (e.g. direction: DOWN | RIGHT).",
          "type": "object",
          "properties": {
            "direction": {
              "type": "string"
            }
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "title",
        "kind"
      ],
      "additionalProperties": {},
      "description": "A stored map definition (docs/spec/maps.md § MapDefinition)."
    },
    "Node": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique node ID. Convention: prefix with species — F- (flow), V- (view), DM- (data-model), API- (api-endpoint)."
        },
        "project_id": {
          "type": "string",
          "description": "Must match project.id."
        },
        "species": {
          "$ref": "#/$defs/Species"
        },
        "title": {
          "type": "string",
          "description": "Human-readable node title."
        },
        "description": {
          "description": "Optional description of the node's purpose.",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "platforms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Platform"
          },
          "description": "One or more target platforms."
        },
        "metadata": {
          "$ref": "#/$defs/NodeMetadata"
        }
      },
      "required": [
        "id",
        "project_id",
        "species",
        "title",
        "status",
        "platforms"
      ],
      "additionalProperties": false
    },
    "Species": {
      "type": "string",
      "enum": [
        "flow",
        "view",
        "data-model",
        "api-endpoint",
        "acceptance"
      ],
      "description": "The species of a node. flow = ordered sequence of views/sub-flows. view = reusable page or screen. data-model = data entity/table. api-endpoint = API endpoint. acceptance = a testable promise (one Given/When/Then) with per-platform status."
    },
    "Status": {
      "type": "string",
      "enum": [
        "idea",
        "backlog",
        "prioritized",
        "development",
        "releasing",
        "live",
        "archived",
        "blocked"
      ],
      "description": "Lifecycle status of a node."
    },
    "Platform": {
      "type": "string",
      "enum": [
        "web",
        "ios",
        "android"
      ],
      "description": "Target platform."
    },
    "NodeMetadata": {
      "type": "object",
      "properties": {
        "stage": {
          "type": "string"
        },
        "playlist": {
          "$ref": "#/$defs/FlowPlaylist"
        },
        "platformNotes": {
          "$ref": "#/$defs/PlatformNotesMap"
        },
        "platformStatuses": {
          "$ref": "#/$defs/PlatformStatusMap"
        },
        "platformScreenshots": {
          "$ref": "#/$defs/PlatformScreenshotsMap"
        },
        "refs": {
          "description": "Typed external references on the node.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Ref"
          }
        },
        "gherkin": {
          "description": "Acceptance nodes only: exactly one Given/When/Then scenario (the How). A second scenario is a second acceptance node.",
          "type": "string"
        },
        "values": {
          "description": "Acceptance nodes only: 1..n Bain value elements served (the Why).",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Value"
          }
        }
      },
      "additionalProperties": {},
      "description": "Optional metadata for a node."
    },
    "FlowPlaylist": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PlaylistEntry"
          }
        }
      },
      "required": [
        "entries"
      ],
      "additionalProperties": false
    },
    "PlaylistEntry": {
      "description": "An entry in a flow's playlist. Discriminated union on 'type'.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "view"
            },
            "view_id": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "view_id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "flow"
            },
            "flow_id": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "flow_id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "condition"
            },
            "label": {
              "type": "string"
            },
            "if_true": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PlaylistEntry"
              }
            },
            "if_false": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PlaylistEntry"
              }
            }
          },
          "required": [
            "type",
            "label",
            "if_true",
            "if_false"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "junction"
            },
            "label": {
              "type": "string"
            },
            "cases": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/JunctionCase"
              }
            }
          },
          "required": [
            "type",
            "label",
            "cases"
          ],
          "additionalProperties": false
        }
      ]
    },
    "JunctionCase": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PlaylistEntry"
          }
        }
      },
      "required": [
        "label",
        "entries"
      ],
      "additionalProperties": false
    },
    "PlatformNotesMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/Platform"
      },
      "additionalProperties": {
        "type": "string"
      },
      "description": "Freeform per-platform notes."
    },
    "PlatformStatusMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/Platform"
      },
      "additionalProperties": {
        "$ref": "#/$defs/Status"
      },
      "description": "Per-platform status overrides for view nodes."
    },
    "PlatformScreenshotsMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/Platform"
      },
      "additionalProperties": {
        "type": "string"
      },
      "description": "Per-platform screenshot: a relative path, an absolute URL, or a data URI (see docs/spec/bundle-format.md § Asset Values)."
    },
    "Ref": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique within the node, kebab-case (e.g. \"gh-142\")."
        },
        "type": {
          "type": "string",
          "description": "Ref type: figma | github-issue | gitlab-issue | linear-issue | github-pr | gitlab-mr | url. Unrecognized values are preserved and render as generic links."
        },
        "url": {
          "type": "string",
          "description": "Canonical external URL."
        },
        "title": {
          "description": "Display label.",
          "type": "string"
        },
        "external_status": {
          "description": "Mirrored external state, verbatim (e.g. \"open\", \"merged\", \"In Progress\").",
          "type": "string"
        },
        "status_mapped": {
          "description": "Optional mapping of external_status into the arkaik lifecycle. Advisory display data — never mutates node.status.",
          "$ref": "#/$defs/Status"
        },
        "platform": {
          "description": "Optional scoping to one platform variant.",
          "$ref": "#/$defs/Platform"
        },
        "synced_at": {
          "description": "ISO 8601 — when external_status was last mirrored.",
          "type": "string"
        }
      },
      "required": [
        "id",
        "type",
        "url"
      ],
      "additionalProperties": false,
      "description": "A typed external reference on a node (docs/spec/bundle-format.md § References)."
    },
    "Value": {
      "type": "string",
      "enum": [
        "saves-time",
        "simplifies",
        "makes-money",
        "reduces-risk",
        "organizes",
        "integrates",
        "connects",
        "reduces-effort",
        "avoids-hassles",
        "reduces-cost",
        "quality",
        "variety",
        "sensory-appeal",
        "informs",
        "reduces-anxiety",
        "rewards-me",
        "nostalgia",
        "design-aesthetics",
        "badge-value",
        "wellness",
        "therapeutic-value",
        "fun-entertainment",
        "attractiveness",
        "provides-access",
        "provides-hope",
        "self-actualization",
        "motivation",
        "heirloom",
        "affiliation-belonging",
        "self-transcendence"
      ],
      "description": "A Bain B2C Elements-of-Value element served by an acceptance (spec §3.2)."
    },
    "Edge": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique edge ID. Convention: e-{source_id}-{target_id}."
        },
        "project_id": {
          "type": "string",
          "description": "Must match project.id."
        },
        "source_id": {
          "type": "string",
          "description": "ID of the source node."
        },
        "target_id": {
          "type": "string",
          "description": "ID of the target node."
        },
        "edge_type": {
          "$ref": "#/$defs/EdgeType"
        },
        "metadata": {
          "description": "Optional edge metadata.",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "project_id",
        "source_id",
        "target_id",
        "edge_type"
      ],
      "additionalProperties": false
    },
    "EdgeType": {
      "type": "string",
      "enum": [
        "composes",
        "calls",
        "displays",
        "queries",
        "covers"
      ],
      "description": "composes = structural hierarchy (flow↔view). calls = view/flow → api-endpoint, or api-endpoint → api-endpoint (endpoint fan-out to internal/external APIs). displays = view → data-model. queries = api-endpoint → data-model. covers = acceptance → view/flow (which surface the acceptance is proven on)."
    },
    "JournalEvent": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "ULID — sortable, collision-free without coordination."
        },
        "ts": {
          "type": "string",
          "description": "ISO 8601 timestamp."
        },
        "actor": {
          "description": "Who/what wrote it (e.g. \"claude-code\", \"ci\").",
          "type": "string"
        },
        "v": {
          "description": "Reserved per-event payload version; absent today.",
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "type": {
          "type": "string",
          "description": "Event type — the v1 vocabulary in docs/spec/journal.md, or an unknown forward-compatible value."
        }
      },
      "required": [
        "id",
        "ts",
        "type"
      ],
      "additionalProperties": true,
      "description": "One append-only journal event. Type-specific payload fields sit flat on the object; unknown types and fields are preserved on rewrite (forward compatibility). See docs/spec/journal.md."
    }
  }
}
