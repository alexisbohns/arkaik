{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkaik.app/schema/project-bundle.json",
  "version": 2,
  "title": "Arkaik ProjectBundle",
  "description": "The import/export format for an Arkaik product graph. Contains a project, its nodes (flows, views, data models, API endpoints), and edges (relationships between nodes).",
  "type": "object",
  "required": [
    "project",
    "nodes",
    "edges"
  ],
  "additionalProperties": true,
  "properties": {
    "project": {
      "$ref": "#/$defs/Project"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Node"
      },
      "description": "All nodes in the project graph."
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Edge"
      },
      "description": "All edges (relationships) between nodes."
    }
  },
  "$defs": {
    "Project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique project identifier."
        },
        "title": {
          "type": "string",
          "description": "Project title."
        },
        "description": {
          "description": "Optional project description.",
          "type": "string"
        },
        "root_node_id": {
          "description": "ID of the root node used as the canvas entry point. Should reference an existing node.",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/ProjectMetadata"
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 creation timestamp."
        },
        "updated_at": {
          "type": "string",
          "description": "ISO 8601 last-update timestamp."
        },
        "archived_at": {
          "description": "ISO 8601 archive timestamp, or null if active.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "title",
        "created_at",
        "updated_at"
      ],
      "additionalProperties": true
    },
    "ProjectMetadata": {
      "type": "object",
      "properties": {
        "view_card_variant": {
          "type": "string",
          "enum": [
            "compact",
            "large"
          ]
        }
      },
      "additionalProperties": {},
      "description": "Optional project-level UI settings."
    },
    "Node": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique node ID. Convention: prefix with species — F- (flow), V- (view), DM- (data-model), API- (api-endpoint)."
        },
        "project_id": {
          "type": "string",
          "description": "Must match project.id."
        },
        "species": {
          "$ref": "#/$defs/Species"
        },
        "title": {
          "type": "string",
          "description": "Human-readable node title."
        },
        "description": {
          "description": "Optional description of the node's purpose.",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "platforms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Platform"
          },
          "description": "One or more target platforms."
        },
        "metadata": {
          "$ref": "#/$defs/NodeMetadata"
        }
      },
      "required": [
        "id",
        "project_id",
        "species",
        "title",
        "status",
        "platforms"
      ],
      "additionalProperties": false
    },
    "Species": {
      "type": "string",
      "enum": [
        "flow",
        "view",
        "data-model",
        "api-endpoint"
      ],
      "description": "The species of a node. flow = ordered sequence of views/sub-flows. view = reusable page or screen. data-model = data entity/table. api-endpoint = API endpoint."
    },
    "Status": {
      "type": "string",
      "enum": [
        "idea",
        "backlog",
        "prioritized",
        "development",
        "releasing",
        "live",
        "archived",
        "blocked"
      ],
      "description": "Lifecycle status of a node."
    },
    "Platform": {
      "type": "string",
      "enum": [
        "web",
        "ios",
        "android"
      ],
      "description": "Target platform."
    },
    "NodeMetadata": {
      "type": "object",
      "properties": {
        "stage": {
          "type": "string"
        },
        "playlist": {
          "$ref": "#/$defs/FlowPlaylist"
        },
        "platformNotes": {
          "$ref": "#/$defs/PlatformNotesMap"
        },
        "platformStatuses": {
          "$ref": "#/$defs/PlatformStatusMap"
        },
        "platformScreenshots": {
          "$ref": "#/$defs/PlatformScreenshotsMap"
        }
      },
      "additionalProperties": {},
      "description": "Optional metadata for a node."
    },
    "FlowPlaylist": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PlaylistEntry"
          }
        }
      },
      "required": [
        "entries"
      ],
      "additionalProperties": false
    },
    "PlaylistEntry": {
      "description": "An entry in a flow's playlist. Discriminated union on 'type'.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "view"
            },
            "view_id": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "view_id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "flow"
            },
            "flow_id": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "flow_id"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "condition"
            },
            "label": {
              "type": "string"
            },
            "if_true": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PlaylistEntry"
              }
            },
            "if_false": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PlaylistEntry"
              }
            }
          },
          "required": [
            "type",
            "label",
            "if_true",
            "if_false"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "junction"
            },
            "label": {
              "type": "string"
            },
            "cases": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/JunctionCase"
              }
            }
          },
          "required": [
            "type",
            "label",
            "cases"
          ],
          "additionalProperties": false
        }
      ]
    },
    "JunctionCase": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PlaylistEntry"
          }
        }
      },
      "required": [
        "label",
        "entries"
      ],
      "additionalProperties": false
    },
    "PlatformNotesMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/Platform"
      },
      "additionalProperties": {
        "type": "string"
      },
      "description": "Freeform per-platform notes."
    },
    "PlatformStatusMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/Platform"
      },
      "additionalProperties": {
        "$ref": "#/$defs/Status"
      },
      "description": "Per-platform status overrides for view nodes."
    },
    "PlatformScreenshotsMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/Platform"
      },
      "additionalProperties": {
        "type": "string"
      },
      "description": "Per-platform screenshot: a relative path, an absolute URL, or a data URI (see docs/spec/bundle-format.md § Asset Values)."
    },
    "Edge": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique edge ID. Convention: e-{source_id}-{target_id}."
        },
        "project_id": {
          "type": "string",
          "description": "Must match project.id."
        },
        "source_id": {
          "type": "string",
          "description": "ID of the source node."
        },
        "target_id": {
          "type": "string",
          "description": "ID of the target node."
        },
        "edge_type": {
          "$ref": "#/$defs/EdgeType"
        },
        "metadata": {
          "description": "Optional edge metadata.",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "project_id",
        "source_id",
        "target_id",
        "edge_type"
      ],
      "additionalProperties": false
    },
    "EdgeType": {
      "type": "string",
      "enum": [
        "composes",
        "calls",
        "displays",
        "queries"
      ],
      "description": "composes = structural hierarchy (flow↔view). calls = view/flow → api-endpoint. displays = view → data-model. queries = api-endpoint → data-model."
    }
  }
}
